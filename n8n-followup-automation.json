              "id": "condition-opt-in",
              "leftValue": "={{ String($json.opt_in).toUpperCase() }}",
              "rightValue": "TRUE",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            },
            {
              "id": "condition-status",
              "leftValue": "={{ $json.status }}",
              "rightValue": "ACTIVE",
              "operator": {
